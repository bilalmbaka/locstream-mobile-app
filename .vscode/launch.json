{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "dev",
      "request": "launch",
      "type": "dart",
      "args": [
        "--flavor",
        "dev",
        "--target",
        "lib/main_dev.dart",
        "--dart-define=baseUrl=http://127.0.0.1:3001/api/v1",
        "--dart-define=socketUrl=ws://127.0.0.1:3001"
      ]
    },
    {
      "name": "staging",
      "request": "launch",
      "type": "dart",
      "args": [
        "--flavor",
        "staging",
        "--target",
        "lib/main_staging.dart",
        "--dart-define=baseUrl=https:///api/v1",
        "--dart-define=cryptoSocketUrl=wss://"
      ]
    },
    {
      "name": "production",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": [
        "--target",
        "main.dart",
        "--dart-define=baseUrl=https:///api/v1",
        "--dart-define=cryptoSocketUrl=wss://"
      ]
    }
  ]
}
